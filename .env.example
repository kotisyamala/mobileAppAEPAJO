# Aether Connect - Adobe Journey Optimizer (AJO) Configuration Example
# Copy this file to .env and fill in your Adobe Experience Platform details.

# AEP Edge Datastream configuration ID
VITE_AEP_DATASTREAM_ID="your_datastream_id_here"

# Adobe Experience Cloud Org ID (e.g. 123456789@AdobeOrg)
VITE_AEP_ORG_ID="your_org_id_here"

# AJO Surface URIs configured in Experience Decisioning
VITE_AJO_SURFACE_POPUP="mobileapp://aether-connect/reload-popup"
VITE_AJO_SURFACE_DASHBOARD="mobileapp://aether-connect/dashboard-banner"
